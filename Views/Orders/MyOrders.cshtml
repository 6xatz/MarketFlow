@model List<Marketplace.Models.Order>
@{
    ViewData["Title"] = "Pesanan Saya";
}

<div class="page-container">
    <div class="page-header">
        <h1>Pesanan Saya</h1>
    </div>

    @if (Model.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-icon">🛒</div>
            <h3>Belum ada pesanan</h3>
            <p>Mulai berbelanja untuk melihat pesanan di sini</p>
            <a href="/Shop" class="btn-primary">Mulai Belanja</a>
        </div>
    }
    else
    {
        <div class="orders-list">
            @foreach (var order in Model)
            {
                <div class="order-card">
                    <div class="order-header">
                        <div>
                            <h3>@order.OrderNumber</h3>
                            <p class="order-date">@order.CreatedAt.ToString("dd MMMM yyyy HH:mm")</p>
                        </div>
                        <div class="order-status status-@order.Status.ToLower()">
                            @order.Status
                        </div>
                    </div>
                    
                    <div class="order-items">
                        @foreach (var item in order.OrderItems)
                        {
                            <div class="order-item">
                                <div class="item-info">
                                    <h4>@item.Product.Name</h4>
                                    <p>Qty: @item.Quantity × Rp @item.Price.ToString("N0")</p>
                                </div>
                                <div class="item-total">
                                    Rp @((item.Price * item.Quantity).ToString("N0"))
                                </div>
                            </div>
                        }
                    </div>

                    @if (!string.IsNullOrEmpty(order.ShippingProofImageUrl))
                    {
                        <div class="shipping-proof">
                            <h4>📸 Bukti Pengiriman</h4>
                            <img src="@order.ShippingProofImageUrl" alt="Bukti Pengiriman" class="proof-image" />
                        </div>
                    }

                    <div class="order-footer">
                        <div class="order-total">
                            <strong>Total: Rp @order.TotalAmount.ToString("N0")</strong>
                        </div>
                        <a href="/Orders/ExportPdf/@order.Id" class="btn-secondary">Download Struk PDF</a>
                    </div>
                </div>
            }
        </div>
    }
</div>

