@{
    ViewData["Title"] = "Home";
}

<section class="hero-section">
    <div class="hero-content">
        <div class="hero-text">
            <h1 class="hero-title">Marketplace Modern</h1>
            <p class="hero-subtitle">Platform jual beli terpercaya dengan pengalaman yang mudah dan aman</p>
            <div class="hero-buttons">
                <a href="/Shop" class="btn-hero btn-primary">Jelajahi Produk</a>
                <a href="/Account/Register" class="btn-hero btn-secondary">Daftar Sekarang</a>
            </div>
        </div>
        <div class="hero-image">
            <div class="floating-card card-1">🛍️</div>
            <div class="floating-card card-2">📦</div>
            <div class="floating-card card-3">💳</div>
        </div>
    </div>
</section>

<section class="features-section">
    <div class="container">
        <h2 class="section-title">Mengapa Pilih Kami?</h2>
        <div class="features-grid">
            <div class="feature-box">
                <div class="feature-icon">🛒</div>
                <h3>Belanja Mudah</h3>
                <p>Proses pembelian yang cepat dan sederhana</p>
            </div>
            <div class="feature-box">
                <div class="feature-icon">📸</div>
                <h3>Bukti Pengiriman</h3>
                <p>Lihat bukti pengiriman barang secara real-time</p>
            </div>
            <div class="feature-box">
                <div class="feature-icon">📄</div>
                <h3>Struk Digital</h3>
                <p>Download struk pembelian dalam format PDF</p>
            </div>
            <div class="feature-box">
                <div class="feature-icon">🔒</div>
                <h3>Aman & Terpercaya</h3>
                <p>Keamanan data dan transaksi terjamin</p>
            </div>
        </div>
    </div>
</section>

<section class="cta-section">
    <div class="container">
        <div class="cta-content">
            <h2>Siap Memulai?</h2>
            <p>Bergabunglah dengan ribuan pengguna yang sudah mempercayai kami</p>
            <a href="/Account/Register" class="btn-cta">Daftar Gratis</a>
        </div>
    </div>
</section>
